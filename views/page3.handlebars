<html lang="en">
<head>
  <meta charset="utf-8"/>
  <!-- passed in variables in handlebars are surrounded by two curly braces like the following
       Any variable you pass into res.render will be available by name in the template through
       the curly braces
  -->
  <title>{{title}}</title>
</head>
<body>
  <h1>Welcome to page 3</h1>
  
  <!-- links or URLs are always GET resources as they are getting (retrieving) a resource -->
  <a href="/">Home</a>
  <a href="/page1">Page 1</a>
  <a href="/page2">Page 2</a>
    <a href="/page4">Page 4</a>

<section>
    <h2>Create a New Dog</h2>
    <form action="/createDog" method="POST">
      <label for="name">Name:</label>
      <input type="text" name="name" value=""/>
      
      <label for="breed">Breed:</label>
      <input type="text" name="breed" value=""/>
      
      <label for="age">Age:</label>
      <input type="number" name="age" value=""/>
      
      <button type="submit">Create Dog</button>
    </form>
  </section>

  <hr />

  <section>
    <h2>Update Dog Age</h2>
    <form action="/updateDogAge" method="POST">
      <label for="searchName">Enter Dog Name:</label>
      <input id="searchName" type="text" name="name" placeholder="Search by name..." required />
      
      <button type="submit">Increase Age by 1</button>
    </form>
  </section>  
</body>
</html>