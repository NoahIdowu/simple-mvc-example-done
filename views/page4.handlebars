<html lang="en">
<head>
  <meta charset="utf-8"/>
  <title>Page 4 - Dog List</title>
</head>
<body>
  <h1>All Dogs</h1>
  
  <nav>
    <a href="/">Home</a>
    <a href="/page1">Page 1</a>
    <a href="/page2">Page 2</a>
    <a href="/page3">Page 3</a>
  </nav>

  <hr />

  <ul>
    {{#each dogs}}
      <li>
        <strong>Name:</strong> {{this.name}} | 
        <strong>Breed:</strong> {{this.breed}} | 
        <strong>Age:</strong> {{this.age}}
      </li>
    {{else}}
      <li>No dogs found in the database. Go to Page 3 to add one!</li>
    {{/each}}
  </ul>

</body>
</html>